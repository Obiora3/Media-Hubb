{
  "name": "mediahubb-root",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/web",
    "packages/supabase"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=packages/web",
    "build": "cd packages/web && npm run build",
    "preview": "npm run preview --workspace=packages/web",
    "db:push": "npm run db:push --workspace=packages/supabase",
    "db:reset": "npm run db:reset --workspace=packages/supabase",
    "functions:deploy": "npm run deploy --workspace=packages/supabase"
  }
}
